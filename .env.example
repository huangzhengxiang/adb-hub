# Required when ADB_HUB_AUTH_REQUIRED=true.
# Generate a local secret with: python -c "import secrets; print(secrets.token_urlsafe(48))"
ADB_HUB_AUTH_SECRET=<replace-with-local-secret>

# Optional service/session settings.
ADB_HUB_PORT=3588
ADB_HUB_AUTH_REQUIRED=true
ADB_HUB_REQUIRE_ENCRYPTED_PAYLOAD=true

# HTTP API address of adb-server, reachable from the remote client / runner.
ADB_HUB_PUBLIC_HOST=<adb-server-http-host-or-ip>

ADB_HUB_SESSION_ROOT=session_workdirs
ADB_HUB_DEVICE_SESSION_ROOT=/data/local/tmp/adb-hub
# Whether close-session removes the Android-side session workdir.
ADB_HUB_CLEAN_DEVICE_SESSION_ROOT=false
# Default SSH/SCP address of the remote client, reachable from adb-server.
# Per-session encrypted create-session payloads may override these values.
# adb-server uses the session endpoint to scp-download artifacts into its session workdir.
ADB_HUB_SCP_HOST=<remote-client-ssh-host-or-ip>
# Empty means using ssh/scp default port 22.
ADB_HUB_SCP_PORT=
ADB_HUB_SCP_PASSWORD=
ADB_HUB_SCP_USER=<ssh-user>
# Number of additional SCP fetch attempts after the initial failure.
ADB_HUB_SCP_FETCH_RETRIES=3
