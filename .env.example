# Required when ADB_HUB_AUTH_REQUIRED=true.
# Generate a local secret with: python -c "import secrets; print(secrets.token_urlsafe(48))"
ADB_HUB_AUTH_SECRET=<replace-with-local-secret>

# Optional service/session settings.
ADB_HUB_AUTH_REQUIRED=true
ADB_HUB_REQUIRE_ENCRYPTED_PAYLOAD=true
ADB_HUB_SESSION_ROOT=session_workdirs
ADB_HUB_DEVICE_SESSION_ROOT=/data/local/tmp/adb-hub
ADB_HUB_SCP_HOST=<machine-a-hostname-or-ip>
ADB_HUB_SCP_USER=<machine-a-ssh-user>
